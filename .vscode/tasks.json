{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                ".",
                "-B",
                "build",
                "-G",
                "Visual Studio 17 2022",
                "-A",
                "x64"
            ],
            "problemMatcher": []
        },
        {
            "label": "build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--config",
                "Debug"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": "configure",
            "problemMatcher": [
                "$msCompile"
            ]
        },
        {
            "label": "test",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "build",
                "-C",
                "Debug",
                "--output-on-failure"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "dependsOn": "build",
            "problemMatcher": []
        }
    ]
}
